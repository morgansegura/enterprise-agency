{
  "name": "platform",
  "version": "0.1.0",
  "description": "Enterprise Agency platform — Payload 3 + Next 16 (Postgres)",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 4010",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 4010",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/plugin-form-builder": "3.85.0",
    "@payloadcms/plugin-multi-tenant": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@puckeditor/core": "0.21.2",
    "@tailwindcss/postcss": "^4",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
