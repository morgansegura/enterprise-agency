# Render external Postgres URL (append ?sslmode=require)
DATABASE_URI=postgres://user:password@host:5432/dbname?sslmode=require
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-me

# Cloudflare R2 media storage (optional — omit in dev to use local disk).
# Endpoint is shown in R2 dashboard as "S3 API" endpoint.
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
