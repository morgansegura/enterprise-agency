# Contact + newsletter forms (Resend email). Copy to `.env.local` and fill.
# Get a key at https://resend.com. Until the brand domain is verified, keep
# RESEND_FROM as the onboarding sender (delivers to the Resend account owner only).

RESEND_API_KEY=
# From sender — verified domain in prod, e.g. "Emily Green <noreply@emilygreen.com>"
RESEND_FROM="Emily Green <onboarding@resend.dev>"
# Optional reply-to on outgoing mail
RESEND_REPLY_TO=
# Where contact inquiries + newsletter signups are emailed
CONTACT_TO=
