{
  "name": "agency",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "Agency monorepo — central Payload CMS (apps/cms) + client FE apps (apps/*), scaffolded from templates/site.",
  "author": "Morgan Segura",
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "new-site": "node scripts/new-site.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\""
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.2"
  }
}
