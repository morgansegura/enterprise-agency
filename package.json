{
  "name": "agency-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Professional Agency Platform - Multi-tenant website builder with token-based design system",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "dev": "pnpm --parallel --stream run dev",
    "dev:client": "pnpm --filter client run dev --port 4002",
    "dev:builder": "pnpm --filter builder run dev --port 4001",
    "dev:api": "pnpm --filter api run dev",
    "build": "pnpm --recursive run build",
    "build:packages": "pnpm --filter @enterprise/tokens --filter @enterprise/blocks --filter @enterprise/media --filter @enterprise/ui run build",
    "build:client": "pnpm run build:packages && pnpm --filter client run build",
    "build:builder": "pnpm run build:packages && pnpm --filter builder run build",
    "build:api": "pnpm --filter api run build",
    "test": "pnpm --recursive run test",
    "test:client": "pnpm --filter client run test",
    "test:builder": "pnpm --filter builder run test",
    "test:api": "pnpm --filter api run test",
    "lint": "pnpm --recursive run lint",
    "lint:fix": "pnpm --recursive run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --recursive run typecheck",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "verify:api": "cd api && pnpm verify",
    "verify:builder": "cd builder && pnpm verify",
    "verify:client": "cd client && pnpm verify",
    "verify:all": "pnpm verify:api && pnpm verify:builder && pnpm verify:client",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:push": "pnpm --filter api run db:push",
    "db:seed": "pnpm --filter api run db:seed",
    "db:studio": "pnpm --filter api run db:studio",
    "db:reset": "pnpm --filter api run db:reset"
  },
  "lint-staged": {
    "api/**/*.ts": [
      "bash -c 'cd api && pnpm lint --fix'"
    ],
    "builder/**/*.{ts,tsx}": [
      "bash -c 'cd builder && pnpm lint --fix'"
    ],
    "client/**/*.{ts,tsx}": [
      "bash -c 'cd client && pnpm lint --fix'"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.2",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "multi-tenant",
    "cms",
    "nextjs",
    "nestjs",
    "prisma",
    "monorepo",
    "web-and-funnel"
  ],
  "author": "Morgan Segura",
  "license": "UNLICENSED",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "bcrypt",
      "esbuild",
      "sharp",
      "@prisma/engines"
    ]
  }
}
