#!/bin/sh

echo "Running pre-push verification..."

BRANCH=$(git rev-parse --abbrev-ref HEAD)

REMOTE_REF="origin/main"
if git rev-parse --verify "origin/$BRANCH" > /dev/null 2>&1; then
  REMOTE_REF="origin/$BRANCH"
fi

CHANGED_FILES=$(git diff --name-only "$REMOTE_REF"...HEAD 2>/dev/null || git diff --name-only HEAD~10...HEAD)

CMS_FILES=$(echo "$CHANGED_FILES" | grep "^apps/cms/.*\.tsx\?$" || true)
CVFC_FILES=$(echo "$CHANGED_FILES" | grep "^apps/cvfc/.*\.tsx\?$" || true)

FAILED=0

if [ -n "$CMS_FILES" ]; then
  echo "CMS changes detected - running typecheck..."
  (cd apps/cms && bunx tsc --noEmit) || FAILED=1
fi

if [ -n "$CVFC_FILES" ]; then
  echo "cvfc changes detected - running lint & typecheck..."
  (cd apps/cvfc && bun run lint && bunx tsc --noEmit) || FAILED=1
fi

if [ -z "$CMS_FILES" ] && [ -z "$CVFC_FILES" ]; then
  echo "No app TypeScript changes detected, skipping verification"
fi

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "Pre-push verification failed! Fix errors before pushing."
  exit 1
fi

echo "Pre-push verification passed!"
