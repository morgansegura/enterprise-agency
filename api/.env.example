# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================

# Environment
NODE_ENV=development # development, staging, production

# Server
PORT=4000

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/webfunnel_dev?schema=public

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Clerk (if using Clerk for auth)
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# JWT (if using custom JWT auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# FRONTEND URLS (for CORS)
# ============================================================================

# Client app URL
APP_URL=http://localhost:4002

# Admin dashboard URL
ADMIN_URL=http://localhost:4001

# ============================================================================
# FILE STORAGE
# ============================================================================

# Storage Provider: 'local' (development) | 'r2' (production with Cloudflare)
STORAGE_PROVIDER=local

# Cloudflare R2 (S3-compatible object storage)
# Get credentials from Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=webfunnel-assets

# Optional: Custom domain for R2 bucket (for CDN)
# Configure at Cloudflare Dashboard → R2 → Settings → Public Bucket URL
# R2_PUBLIC_URL=https://assets.yourdomain.com

# Alternative: AWS S3 (if not using R2)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_BUCKET_NAME=webfunnel-assets
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# ============================================================================
# PAYMENT PROVIDERS
# ============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Square (alternative to Stripe)
# SQUARE_ACCESS_TOKEN=your-access-token
# SQUARE_LOCATION_ID=your-location-id
# SQUARE_WEBHOOK_SIGNATURE_KEY=your-signature-key

# ============================================================================
# EMAIL SERVICE
# ============================================================================

# SendGrid
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Resend (alternative to SendGrid)
# RESEND_API_KEY=re_xxxxx

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Sentry (error tracking and performance monitoring)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Enable Sentry in development (default: disabled, only production)
SENTRY_ENABLED=false

# LogDNA / Datadog / New Relic (optional)
# LOGDNA_INGESTION_KEY=xxxxx

# ============================================================================
# RATE LIMITING
# ============================================================================

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable specific features globally
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true
